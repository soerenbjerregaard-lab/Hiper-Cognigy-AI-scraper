// ===== SAMLINGSFUNKTION =====\par
\par
function collectRelevantDomainKnowledge(context) \{\par
  const knowledgeMap = \{\par
    offline: offlineDomainKnowledge,\par
    ustabil: ustabilDomainKnowledge,\par
    hastighed: hastighedDomainKnowledge,\par
    internet_generel: internetGenerelDomainKnowledge,\par
    udstyr: udstyrDomainKnowledge,\par
    etablering: etableringDomainKnowledge,\par
    sbbu: sbbuDomainKnowledge,\par
    flytning: flytningDomainKnowledge,\par
    overdragelse: overdragelseDomainKnowledge,\par
    regning: regningDomainKnowledge,\par
    mithiper: mithiperDomainKnowledge,\par
    sale: saleDomainKnowledge,\par
    gdpr: gdprDomainKnowledge,\par
  \};\par
\par
  const chosenCategories = context.categoriesChosen\par
    ? context.categoriesChosen.split(",").map(c => c.trim())\par
    : [];\par
\par
  const priorityOrder = [\par
    context.prioritisedCategory,\par
    ...chosenCategories\par
  ].filter((v, i, a) => v && a.indexOf(v) === i);\par
\par
  const relevantKnowledge = priorityOrder\par
    .slice(0, 3)\par
    .map(cat => knowledgeMap[cat])\par
    .filter(Boolean);\par
\par
  return relevantKnowledge.length > 0\par
    ? relevantKnowledge.join("\\n")\par
    : "";\par
\}\par
\par
let domainKnowledge = collectRelevantDomainKnowledge(context);\par
